# deploy/.env.example —— 复制为 deploy/.env 后填写（deploy/.env 已被 .gitignore 忽略，不会提交）
# 也可在目标 VPS 上由 install.sh 交互生成，无需手动维护此文件。

# 管理面板登录密码（install.sh 会据此写入 /opt/sub-converter/.env）
ZSM_PASS=your-strong-admin-password

# 订阅域名（用于面板展示端点 URL 与 Nginx server_name）
SUB_DOMAIN=sub.example.com

# SSL 证书路径（按你的证书实际位置修改）
NGINX_CERT_FULL=/etc/letsencrypt/live/sub.example.com/fullchain.pem
NGINX_CERT_KEY=/etc/letsencrypt/live/sub.example.com/privkey.pem

# Nginx 站点配置输出路径（宝塔通常是 /www/server/panel/vhost/nginx/；标准 nginx 是 /etc/nginx/conf.d/）
NGINX_CONF_PATH=/etc/nginx/conf.d/sub.example.com.conf
